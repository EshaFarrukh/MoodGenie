# =============================================================================
# MoodGenie — .gitignore
# Flutter mobile app · Next.js admin dashboard · Express backend
# =============================================================================

# -----------------------------------------------------------------------------
# OS-generated files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.class
*.log
*.pyc
*.swp
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
# IntelliJ / Android Studio
*.iml
*.ipr
*.iws
.idea/

# VS Code (uncomment if not sharing workspace settings)
# .vscode/

# -----------------------------------------------------------------------------
# Flutter / Dart / Pub
# -----------------------------------------------------------------------------
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# DevTools (optional — remove if team shares DevTools prefs)
devtools_options.yaml

# -----------------------------------------------------------------------------
# Android
# -----------------------------------------------------------------------------
/android/app/debug
/android/app/profile
/android/app/release
/android/.gradle/
**/android/**/GeneratedPluginRegistrant.java
local.properties

# -----------------------------------------------------------------------------
# iOS / macOS — CocoaPods & ephemeral
# -----------------------------------------------------------------------------
ios/Pods/
macos/Pods/
macos/Flutter/ephemeral/
**/ios/Flutter/flutter_export_environment.sh
**/ios/Flutter/Generated.xcconfig

# -----------------------------------------------------------------------------
# Node.js (backend, admin, firebase_tests)
# -----------------------------------------------------------------------------
node_modules/
**/node_modules/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Next.js (admin dashboard)
# -----------------------------------------------------------------------------
**/.next/
apps/admin/out/

# -----------------------------------------------------------------------------
# Environment & secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
backend/.env
apps/admin/.env.local

# Signing keys & certificates
android/key.properties
ios/Flutter/Signing.xcconfig
macos/Flutter/Signing.xcconfig
*.jks
*.keystore
*.p12
*.pem
*.mobileprovision

# Firebase service account keys (if ever placed locally)
**/serviceAccountKey*.json
**/service-account*.json

# -----------------------------------------------------------------------------
# Local development state
# -----------------------------------------------------------------------------
.local/
backend/server.pid
backend/server.log

# Firebase emulator debug logs
firebase_tests/firestore-debug.log
firebase_tests/ui-debug.log
firebase_tests/pubsub-debug.log
firebase_tests/database-debug.log

# -----------------------------------------------------------------------------
# Build / analysis logs (temporary debugging output)
# -----------------------------------------------------------------------------
build_log*.txt
ios_build*.log
analyze*.log

# -----------------------------------------------------------------------------
# One-off utility scripts (personal, not part of the app)
# -----------------------------------------------------------------------------
*.py

# -----------------------------------------------------------------------------
# Academic / personal documents
# -----------------------------------------------------------------------------
/SRS/
/Proposal/
FYP Registration Form - SE.pdf
